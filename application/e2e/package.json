{
  "name": "@web-speed-hackathon-2026/e2e",
  "version": "0.0.1",
  "private": true,
  "license": "MPL-2.0",
  "author": "CyberAgent, Inc.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc",
    "test": "playwright test",
    "test:heap": "cross-env NODE_OPTIONS=--max-old-space-size=8192 playwright test",
    "test:2:heap": "cross-env NODE_OPTIONS=--max-old-space-size=8192 E2E_WORKERS=2 playwright test",
    "test:2": "cross-env E2E_WORKERS=2 playwright test",
    "test:last-failed": "playwright test --last-failed",
    "test:last-failed:serial": "cross-env E2E_WORKERS=1 playwright test --last-failed",
    "test:serial": "cross-env E2E_WORKERS=1 playwright test",
    "test:update": "playwright test --update-snapshots",
    "test:serial:update": "cross-env E2E_WORKERS=1 playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "1.50.1",
    "cross-env": "7.0.3",
    "@types/node": "22.18.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.32.1"
}
