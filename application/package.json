{
  "name": "@web-speed-hackathon-2026/application",
  "private": true,
  "license": "MPL-2.0",
  "author": "CyberAgent, Inc.",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @web-speed-hackathon-2026/client build",
    "e2e:serve": "pnpm run build && pnpm --filter @web-speed-hackathon-2026/server start",
    "test:e2e": "pnpm --filter @web-speed-hackathon-2026/e2e test",
    "test:e2e:2": "pnpm --filter @web-speed-hackathon-2026/e2e run test:2",
    "test:e2e:heap": "pnpm --filter @web-speed-hackathon-2026/e2e run test:heap",
    "test:e2e:2:heap": "pnpm --filter @web-speed-hackathon-2026/e2e run test:2:heap",
    "test:e2e:last-failed": "pnpm --filter @web-speed-hackathon-2026/e2e run test:last-failed",
    "test:e2e:last-failed:serial": "pnpm --filter @web-speed-hackathon-2026/e2e run test:last-failed:serial",
    "test:e2e:serial": "pnpm --filter @web-speed-hackathon-2026/e2e run test:serial",
    "start": "pnpm --filter @web-speed-hackathon-2026/server start",
    "score:dm": "pnpm --dir ../scoring-tool run score:dm",
    "score:user-flow": "pnpm --dir ../scoring-tool run score:user-flow",
    "typecheck": "pnpm run --recursive typecheck",
    "format": "pnpm run format:oxlint && pnpm run format:oxfmt",
    "format:oxlint": "oxlint --fix",
    "format:oxfmt": "oxfmt"
  },
  "devDependencies": {
    "oxfmt": "0.36.0",
    "oxlint": "1.43.0"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "sqlite3"
    ]
  }
}
